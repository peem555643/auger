# Copy to .env. Never commit the result — it holds the Mongo credentials.

# Atlas:
#   AUGER_MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# A replica set of your own:
#   AUGER_MONGO_URI=mongodb://user:password@10.0.0.11:27017,10.0.0.12:27017/?replicaSet=rs0&authSource=admin
AUGER_MONGO_URI=

# error | warn | info | debug | trace, or a RUST_LOG-style filter such as
# "info,auger::mongo=debug" to see the generated pipelines.
AUGER_LOG=info
