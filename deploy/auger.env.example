# Installed to /etc/auger/auger.env as 0600 root:root — it holds the MongoDB
# credentials, and systemd reads it as PID 1 before dropping privileges, so the
# auger service account never needs to read it itself.
#
# Note this is NOT a shell script: systemd does no variable expansion, no
# command substitution, and quotes are taken literally unless they wrap the
# whole value. Write the URI plainly, with no surrounding quotes.

# Percent-encode any of : / ? # [ ] @ in the password. Use a MongoDB user with
# `read` on the exposed databases only — Auger refuses writes itself, but the
# credential should not be able to perform one either.
AUGER_MONGO_URI=mongodb://auger:CHANGEME@10.199.188.53:27017/?authSource=admin

# Auger has no TLS and its "scram" mode actually performs MD5, so this address
# decides how much exposure the deployment has.
#
#   127.0.0.1:5433   only this host — reach it from elsewhere over an SSH tunnel
#   10.0.0.5:5433    one interface, when clients live on a private network
#   0.0.0.0:5433     every interface; only with a firewall rule in front
#
# Naming the interface explicitly is better than 0.0.0.0 plus a firewall rule,
# because it cannot be undone by someone else's ufw change later.
AUGER_LISTEN=127.0.0.1:5433

# error | warn | info | debug | trace, or a RUST_LOG-style filter such as
# "info,auger::mongo=debug" to log the generated aggregation pipelines.
AUGER_LOG=info
